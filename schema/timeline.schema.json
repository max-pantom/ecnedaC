{
  "$defs": {
    "TimelineEvent": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "intensity": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Intensity",
          "type": "number"
        },
        "pan": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": -1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pan"
        },
        "rationale": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "reverb": {
          "anyOf": [
            {
              "maxLength": 100,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reverb"
        },
        "t_ms": {
          "minimum": 0,
          "title": "T Ms",
          "type": "integer"
        },
        "texture": {
          "anyOf": [
            {
              "maxLength": 100,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Texture"
        },
        "type": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "t_ms",
        "type",
        "duration_ms",
        "intensity",
        "confidence",
        "rationale"
      ],
      "title": "TimelineEvent",
      "type": "object"
    }
  },
  "$id": "https://cadence.local/schema/timeline.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "duration_ms": {
      "exclusiveMinimum": 0,
      "title": "Duration Ms",
      "type": "integer"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/TimelineEvent"
      },
      "title": "Events",
      "type": "array"
    },
    "schema_version": {
      "const": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_video": {
      "maxLength": 255,
      "minLength": 1,
      "title": "Source Video",
      "type": "string"
    },
    "timeline_id": {
      "format": "uuid",
      "title": "Timeline Id",
      "type": "string"
    }
  },
  "required": [
    "timeline_id",
    "source_video",
    "duration_ms",
    "events",
    "schema_version"
  ],
  "title": "CreativeTimeline",
  "type": "object"
}
