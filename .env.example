# Configuration overrides use CADENCE_ with __ for nested fields.
# CADENCE_RUNTIME__SEED=1234
# CADENCE_PATHS__MANIFEST_PATH=/absolute/path/to/manifest.jsonl
# CADENCE_REMOTE__VPS_HOST=user@example.invalid
# CADENCE_REVIEW_ADMIN_SECRET=generate-a-random-value-of-at-least-32-characters
# CADENCE_REVIEW_READONLY_SECRET=runtime-only-and-generated-for-temporary-sharing
# CADENCE_REVIEW_READONLY_MAX_AGE_SECONDS=1800
# CADENCE_REVIEW_SECURE_DEPLOYMENT=false
# RUNPOD_API_KEY=provided-at-runtime-only-never-commit-a-real-key
# VAST_API_KEY=legacy-provider-runtime-only
